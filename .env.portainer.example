# Kopiere diese Werte in Portainer unter "Environment variables"
# oder lege sie als Stack-Env-Datei ab.

ADMIN_NAME=admin
ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=bitte-aendern

# Standardpfad auf Synology. Bei Bedarf an dein Volume anpassen,
# zum Beispiel /volume2/docker/printer-farm-admin/data.
PFA_DATA_DIR=/volume1/docker/printer-farm-admin/data

# Host-Port auf der Synology. Intern nutzt die App weiter Port 3000.
PFA_HTTP_PORT=3000
